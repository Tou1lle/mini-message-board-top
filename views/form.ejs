<!DOCTYPE html>
<html lang="en">

<%- include("partials/head"), { title } %>

<body>
  <h1>New Message</h1>
  <div class="container">

    <div class="main-container">
      <h2>Create new message</h2>
      <form class="main-content main-form" action="/new" method="post">
        <div>
          <label for="user">Name:</label>
          <input type="text" id="user" name="user" required placeholder="Enter your name">
        </div>
        <div>
          <label for="text">Message:</label>
          <textarea name="text" id="text" required placeholder="Type your message"></textarea>
        </div>
        <div class="submit-container"><button type="submit">Create</button></div>
      </form>
    </div>

    <%- include("partials/navlink", { destination: "/", name: "Home" }) %>

  </div>
</body>
</html>