<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
</head>
<body>
  <h1>Database</h1>
  <div>
    <h2>Created Messages</h2>
    <div>
      <% messages.forEach(message => { %>
        <div>
          <h3><%= message.user %></h3>
          <p><span>Created: </span> <%= message.added %></p>
        </div>
        <div>
          <p><%= message.text %></p>
        </div>
      <% }) %>
    </div>
    <div>
      <button>
        <a href="/new">Create New Message</a>
      </button>
    </div>
  </div>
</body>
</html>